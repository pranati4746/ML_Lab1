# A1: BASIC FUNCTIONS
def summation(x, w, b):
    return np.dot(x, w) + b

def step(x):
    return 1 if x >= 0 else 0

def bipolar_step(x):
    return 1 if x >= 0 else -1

def sigmoid(x):
    return 1 / (1 + np.exp(-x))

def tanh(x):
    return np.tanh(x)

def relu(x):
    return max(0, x)

def leaky_relu(x):
    return x if x > 0 else 0.01 * x


def perceptron_train(X, y, w, b, lr, activation, max_epochs=1000):
    errors = []
    
    for epoch in range(max_epochs):
        total_error = 0
        
        for i in range(len(X)):
            net = summation(X[i], w, b)
            y_pred = activation(net)
            
            e = y[i] - y_pred
            total_error += e**2
            
            w = w + lr * e * X[i]
            b = b + lr * e
        
        errors.append(total_error)
        
        if total_error <= 0.002:
            print(f"Converged in {epoch+1} epochs")
            break
    
    return w, b, errors



