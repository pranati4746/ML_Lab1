      #A8: BACKPROPAGATION (MLP
      def train_mlp(X, y, lr=0.05, epochs=1000):
    np.random.seed(0)
    
    W1 = np.random.uniform(-0.5,0.5,(X.shape[1],2))
    W2 = np.random.uniform(-0.5,0.5,(2,1))
    
    for epoch in range(epochs):
        H = sigmoid(np.dot(X, W1))
        O = sigmoid(np.dot(H, W2))
        
        E = y.reshape(-1,1) - O
        
        if np.mean(E**2) <= 0.002:
            print(f"MLP converged in {epoch} epochs")
            break
        
        dO = E * O * (1-O)
        dH = dO.dot(W2.T) * H * (1-H)
        
        W2 += lr * H.T.dot(dO)
        W1 += lr * X.T.dot(dH)
    
    return W1, W2


print("\n--- MLP Training ---")
train_mlp(X, y)


